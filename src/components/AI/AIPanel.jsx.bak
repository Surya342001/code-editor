      {results.slice(0, 5).map((r, i) => (
        <button key={`${r.path}:${r.line||1}:${i}`} onClick={() => navigateTo(r.path, r.line || 1)}
          className="w-full text-left px-3 py-2 hover:bg-[#21262d] border-b border-[#21262d] last:border-b-0 transition-colors">
